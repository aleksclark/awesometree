[Unit]
Description=Awesometree workspace daemon
Documentation=https://github.com/aleksclark/awesometree
PartOf=graphical-session.target
After=graphical-session.target

[Service]
Type=simple
ExecStartPre=-/bin/rm -f /tmp/awesometree.sock
ExecStart=awesometree-daemon
Restart=on-failure
RestartSec=3

[Install]
WantedBy=graphical-session.target
